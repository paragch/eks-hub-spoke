# Terraform
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup
*.tfplan
tfplan
.terraformrc
terraform.rc

# Sensitive files
*.pem
*.key
*.crt
kubeconfig
*kubeconfig
kubeconfig*

# terraform.tfvars contain real account IDs / emails after startup.sh runs.
# Keep only the .example templates in version control.
envs/*/terraform.tfvars

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Scripts output — logs are written to repo root, not scripts/
*.log

# Script checkpoint files
.startup-progress
.apply-all-progress
.teardown-progress
.shutdown-progress

# Terraform crash logs and local override files
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
