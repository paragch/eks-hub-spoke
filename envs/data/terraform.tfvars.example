aws_region   = "eu-west-2"
cluster_name = "eks-data"

# Replace with the actual data account ID from: terraform output -chdir=envs/accounts data_account_id
account_id = "REPLACE_WITH_DATA_ACCOUNT_ID"

vpc_cidr             = "10.3.0.0/16"
public_subnet_cidrs  = ["10.3.0.0/24", "10.3.1.0/24"]
private_subnet_cidrs = ["10.3.10.0/24", "10.3.11.0/24"]

kubernetes_version   = "1.32"
node_instance_type   = "t3.large"
node_desired_size    = 2
node_min_size        = 2
node_max_size        = 6

argocd_chart_version = "7.8.26"
istio_version        = "1.24.3"

# Amazon MQ credentials — change password before first apply (12–250 characters)
mq_username = "admin"
mq_password = "REPLACE_WITH_MQ_PASSWORD"

common_tags = {
  Project     = "eks-hub-spoke"
  Environment = "data"
  ManagedBy   = "terraform"
}
