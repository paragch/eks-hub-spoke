aws_region    = "eu-west-2"
cluster_name  = "eks-hub"
state_bucket  = "REPLACE_WITH_STATE_BUCKET"

# Replace with actual account IDs from: terraform output -chdir=envs/accounts
hub_account_id  = "REPLACE_WITH_HUB_ACCOUNT_ID"
prod_account_id = "REPLACE_WITH_PROD_ACCOUNT_ID"

vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.0.0/24", "10.0.1.0/24"]
private_subnet_cidrs = ["10.0.10.0/24", "10.0.11.0/24"]

kubernetes_version   = "1.32"
node_instance_type   = "t3.medium"
node_desired_size    = 2
node_min_size        = 2
node_max_size        = 4

argocd_chart_version = "7.8.26"

common_tags = {
  Project     = "eks-hub-spoke"
  Environment = "hub"
  ManagedBy   = "terraform"
}
